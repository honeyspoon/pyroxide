#!/usr/bin/env bash
# Pre-commit hook for pyroxide.
# Install: ./scripts/install-hooks.sh

set -e

echo "pre-commit: fmt"
cargo fmt -p pyroxide -p max-sys -- --check

echo "pre-commit: clippy"
cargo clippy -p pyroxide --features max -p max-sys -- -D warnings

echo "pre-commit: machete"
cargo machete

echo "pre-commit: stale refs"
./scripts/check-stale-refs.sh

echo "pre-commit: all checks passed"
